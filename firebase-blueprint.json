{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile with role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "sales"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "email", "role", "createdAt", "updatedAt"]
    },
    "customer": {
      "title": "Customer",
      "description": "Customer/Lead data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "country": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" },
        "salesRepId": { "type": "string" },
        "lastFollowUp": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "company", "country", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/user" },
      "description": "User profiles and roles"
    },
    "/customers/{customerId}": {
      "schema": { "$ref": "#/entities/customer" },
      "description": "All customer records"
    }
  }
}
