rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Catch-All Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (request.auth.token.email == 'agqyed01@gmail.com');
    }

    function getUserRole() {
       return exists(/databases/$(database)/documents/users/$(request.auth.uid))
         ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
         : 'unregistered';
    }

    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && getUserRole() == 'admin');
    }

    function isManager() {
      return isSignedIn() && getUserRole() == 'manager';
    }

    function isSales() {
      return isSignedIn() && getUserRole() == 'sales';
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
       let validKeys = ['uid', 'displayName', 'email', 'role', 'createdAt', 'updatedAt'];
       return data.keys().hasAll(['uid', 'email', 'role', 'createdAt', 'updatedAt'])
           && data.uid == request.auth.uid
           && data.email is string && data.email.size() <= 200
           && data.role in ['admin', 'manager', 'sales']
           && data.createdAt is number
           && data.updatedAt is number
           && (('displayName' in data) == false || (data.displayName is string && data.displayName.size() <= 100));
    }

    function isValidCustomer(data) {
       let validKeys = ['id', 'name', 'company', 'country', 'phone', 'email', 'status', 'salesRepId', 'lastFollowUp', 'createdAt', 'updatedAt'];
       return data.keys().hasAll(['id', 'name', 'company', 'country', 'status', 'createdAt', 'updatedAt'])
           && data.id is string && data.id.size() <= 128
           && data.name is string && data.name.size() <= 200
           && data.company is string && data.company.size() <= 200
           && data.country is string && data.country.size() <= 100
           && data.status in ['In Pool', 'Following Up', 'Claimed', 'Deal Closed']
           && data.createdAt is number
           && data.updatedAt is number
           && (('phone' in data) == false || (data.phone is string && data.phone.size() <= 50))
           && (('email' in data) == false || (data.email is string && data.email.size() <= 200))
           && (('salesRepId' in data) == false || (data.salesRepId is string && data.salesRepId.size() <= 128))
           && (('lastFollowUp' in data) == false || (data.lastFollowUp is string && data.lastFollowUp.size() <= 100));
    }

    // --- Match Rules ---
    match /users/{userId} {
      allow read: if isSignedIn(); // Allow other users to read profiles to see names/roles (Manager/Admin need it, Sales needs to assign??)
      
      allow create: if isSignedIn() 
                    && isValidId(userId)
                    && userId == request.auth.uid
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time.toMillis()
                    && (isSuperAdmin() || incoming().role == 'sales'); // new users default to sales, super admin can insert admins directly
      
      allow update: if isSignedIn()
                    && isValidUser(incoming())
                    && incoming().updatedAt == request.time.toMillis()
                    && incoming().createdAt == existing().createdAt
                    && incoming().uid == existing().uid
                    && (
                      isAdmin() // Admin can change anything
                      || (
                        userId == request.auth.uid
                        && incoming().role == existing().role // Normal user cannot escalate privileges
                        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt'])
                      )
                    );
    }

    match /customers/{customerId} {
      // Admins and Managers can read all.
      // Sales can read if it is in the pool or if they are the assigned rep.
      allow read: if isSignedIn() && (
         isAdmin() || isManager() 
         || existing().status == 'In Pool'
         || ('salesRepId' in existing() && existing().salesRepId == request.auth.uid)
      );

      // Anyone authenticated can create (import to pool etc)
      allow create: if isSignedIn()
                    && isValidId(customerId)
                    && isValidCustomer(incoming())
                    && incoming().createdAt == request.time.toMillis();
      
      // Update rules
      allow update: if isSignedIn()
                    && isValidCustomer(incoming())
                    && incoming().updatedAt == request.time.toMillis()
                    && incoming().createdAt == existing().createdAt
                    && incoming().id == existing().id
                    && (
                       isAdmin() || isManager()
                       || (
                         isSales() && (
                           // Action: Claim Lead from Pool
                           (
                             existing().status == 'In Pool' && 
                             existing().salesRepId == null &&
                             incoming().status != 'In Pool' &&
                             incoming().salesRepId == request.auth.uid &&
                             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'salesRepId', 'updatedAt', 'lastFollowUp'])
                           )
                           ||
                           // Action: Edit Own Lead
                           (
                             existing().salesRepId == request.auth.uid &&
                             incoming().salesRepId == request.auth.uid &&
                             incoming().diff(existing()).affectedKeys().hasOnly(['name', 'company', 'country', 'phone', 'email', 'status', 'lastFollowUp', 'updatedAt'])
                           )
                           ||
                           // Action: Return Lead to Pool
                           (
                             existing().salesRepId == request.auth.uid &&
                             incoming().salesRepId == null &&
                             incoming().status == 'In Pool' &&
                             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'salesRepId', 'updatedAt'])
                           )
                         )
                       )
                    );
                    
      allow delete: if isAdmin() || isManager();
    }
  }
}
